{
    "name": "waaseyaa/northcloud",
    "description": "North Cloud client, content sync, and search provider for Waaseyaa applications",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.4",
        "symfony/console": "^7.0",
        "waaseyaa/config": "^0.1.0-alpha.150",
        "waaseyaa/entity": "^0.1.0-alpha.150",
        "waaseyaa/foundation": "^0.1.0-alpha.150",
        "waaseyaa/http-client": "^0.1.0-alpha.150",
        "waaseyaa/search": "^0.1.0-alpha.150"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\NorthCloud\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\NorthCloud\\Tests\\": "tests/"
        }
    },
    "extra": {
        "waaseyaa": {
            "layer": 2,
            "providers": [
                "Waaseyaa\\NorthCloud\\Provider\\NorthCloudServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
